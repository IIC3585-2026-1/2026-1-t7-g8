---
import BaseLayout from '../layouts/BaseLayout.astro';
import CryptoFilter from '../components/CryptoFilter.vue';
import PriceTicker from '../components/PriceTicker.svelte';
import { COINS, DEFAULT_SELECTION, type Coin } from '../lib/coins';

async function enrich(): Promise<Coin[]> {
  const ids = COINS.map((c) => c.coingeckoId).join(',');
  const url = `https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&ids=${ids}`;
  try {
    const res = await fetch(url, {
      headers: { accept: 'application/json' },
      signal: AbortSignal.timeout(5000),
    });
    if (!res.ok) throw new Error(`coingecko ${res.status}`);
    const rows = (await res.json()) as Array<{
      id: string;
      image?: string;
      name?: string;
      current_price?: number;
      price_change_percentage_24h?: number;
    }>;
    const byId = new Map(rows.map((r) => [r.id, r]));
    return COINS.map((c) => {
      const r = byId.get(c.coingeckoId);
      return {
        ...c,
        iconUrl: r?.image,
        name: r?.name ?? c.name,
        currentPrice: r?.current_price,
        priceChange24h: r?.price_change_percentage_24h,
      };
    });
  } catch (err) {
    console.warn('[index.astro] CoinGecko enrichment skipped:', err);
    return COINS;
  }
}

const coins = await enrich();
---

<BaseLayout>
  <section class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-6">
    <CryptoFilter client:load coins={coins} defaults={DEFAULT_SELECTION} />
    <PriceTicker client:visible coins={coins} />
  </section>
</BaseLayout>
