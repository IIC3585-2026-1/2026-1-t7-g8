---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white">
  <div
    class="w-full max-w-6xl mx-auto px-6 py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 text-sm text-slate-500"
  >
    <p>
      T7 · IIC3585 · {year}
    </p>
    <p class="text-xs">
      Built with
      <span class="font-semibold text-slate-700">Astro</span>
      ·
      <span class="font-semibold text-slate-700">Vue</span>
      ·
      <span class="font-semibold text-slate-700">Svelte</span>
      ·
      <span class="font-semibold text-slate-700">Tailwind</span>
    </p>
  </div>
</footer>
